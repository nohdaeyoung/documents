<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>우리 삶과 죽음은 이대로 괜찮은가</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700;900&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1612;
    --paper: #f5f0e8;
    --cream: #ebe4d6;
    --accent: #8b4513;
    --accent-light: #c4956a;
    --muted: #7a7062;
    --divider: #d4cbb8;
    --highlight: #fff8ed;
    --deep: #2c1810;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    background: var(--deep);
  }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    color: var(--ink);
    background: var(--paper);
    line-height: 1.85;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Hero Section ── */
  .hero {
    background: var(--deep);
    color: var(--paper);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(139,69,19,0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(196,149,106,0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .hero-label {
    font-size: 0.75rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 2.5rem;
    font-weight: 500;
    opacity: 0;
    animation: fadeUp 1s 0.3s forwards;
  }

  .hero h1 {
    font-family: 'Noto Serif KR', serif;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    font-weight: 900;
    line-height: 1.3;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 1s 0.6s forwards;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--accent-light);
  }

  .hero-meta {
    font-size: 0.9rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    opacity: 0;
    animation: fadeUp 1s 0.9s forwards;
  }

  .hero-meta span { margin: 0 0.75rem; }

  .scroll-indicator {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeUp 1s 1.2s forwards, float 3s 2s infinite;
  }

  .scroll-indicator svg {
    width: 24px;
    height: 24px;
    stroke: var(--accent-light);
    stroke-width: 1.5;
    fill: none;
  }

  /* ── Main Content ── */
  .content {
    max-width: 760px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
  }

  /* ── Section ── */
  .section {
    margin-bottom: 4.5rem;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.8s forwards;
  }

  .section:nth-child(1) { animation-delay: 0.1s; }
  .section:nth-child(2) { animation-delay: 0.15s; }
  .section:nth-child(3) { animation-delay: 0.2s; }

  .section-number {
    font-family: 'Noto Serif KR', serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
    display: block;
  }

  .section h2 {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.65rem;
    font-weight: 700;
    color: var(--deep);
    line-height: 1.4;
    margin-bottom: 1.5rem;
    position: relative;
    padding-bottom: 1.25rem;
  }

  .section h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--accent);
  }

  .section p {
    font-size: 1rem;
    color: var(--ink);
    margin-bottom: 1.25rem;
    font-weight: 300;
    line-height: 2;
  }

  /* ── Story Block ── */
  .story-block {
    background: var(--highlight);
    border-left: 3px solid var(--accent);
    padding: 2rem 2rem 2rem 2.5rem;
    margin: 2rem 0;
    border-radius: 0 8px 8px 0;
    position: relative;
  }

  .story-block .icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    display: block;
  }

  .story-block h3 {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--deep);
    margin-bottom: 0.75rem;
  }

  .story-block p {
    font-size: 0.95rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    line-height: 1.9;
  }

  /* ── Comparison ── */
  .compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2.5rem 0;
  }

  @media (max-width: 600px) {
    .compare { grid-template-columns: 1fr; }
  }

  .compare-card {
    padding: 2rem;
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }

  .compare-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }

  .compare-card.left {
    background: #faf5f0;
    border: 1px solid #e8ddd0;
  }
  .compare-card.left::before { background: #b8860b; }

  .compare-card.right {
    background: #f0f5f2;
    border: 1px solid #cdddd4;
  }
  .compare-card.right::before { background: #2e7d5b; }

  .compare-card .label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .compare-card.left .label { color: #b8860b; }
  .compare-card.right .label { color: #2e7d5b; }

  .compare-card h3 {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--deep);
  }

  .compare-card p {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 0;
  }

  /* ── Stat Block ── */
  .stat-row {
    display: flex;
    gap: 1.5rem;
    margin: 2.5rem 0;
    flex-wrap: wrap;
  }

  .stat-item {
    flex: 1;
    min-width: 140px;
    text-align: center;
    padding: 1.75rem 1rem;
    background: var(--cream);
    border-radius: 12px;
  }

  .stat-item .num {
    font-family: 'Noto Serif KR', serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--accent);
    display: block;
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }

  .stat-item .desc {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.5;
    font-weight: 400;
  }

  /* ── Insight (Claude) ── */
  .insight-section {
    background: var(--deep);
    color: var(--paper);
    padding: 5rem 2rem;
    margin-top: 2rem;
  }

  .insight-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .insight-label {
    font-size: 0.7rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .insight-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(196,149,106,0.3);
  }

  .insight-section h2 {
    font-family: 'Noto Serif KR', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 2rem;
    line-height: 1.5;
    color: var(--cream);
  }

  .insight-section p {
    font-size: 0.95rem;
    line-height: 2.1;
    color: rgba(235,228,214,0.8);
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .insight-section p strong {
    color: var(--accent-light);
    font-weight: 500;
  }

  /* ── Footer ── */
  footer {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--deep);
    border-top: 1px solid rgba(196,149,106,0.15);
  }

  footer p {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* ── Flow Diagram ── */
  .flow {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--cream);
    border-radius: 12px;
  }

  .flow-step {
    background: white;
    padding: 0.6rem 1.1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--deep);
    border: 1px solid var(--divider);
    white-space: nowrap;
  }

  .flow-arrow {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 300;
  }

  /* ── Keyframes ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(25px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ── Divider ── */
  .section-divider {
    width: 100%;
    height: 1px;
    background: var(--divider);
    margin: 4rem 0;
    position: relative;
  }

  .section-divider::after {
    content: '◆';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--paper);
    padding: 0 1rem;
    color: var(--accent);
    font-size: 0.6rem;
  }


  /* NAV */
nav{
  position:sticky;top:0;z-index:900;
  background:rgba(13,13,13,.92);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:16px 32px;
  display:flex;align-items:center;justify-content:space-between;
}
.nav-left{display:flex;align-items:center;gap:16px;}
.nav-home{
  display:inline-flex;align-items:center;gap:6px;
  font-family:'JetBrains Mono',monospace;font-size:11px;
  letter-spacing:.08em;color:var(--text-muted);
  text-decoration:none;
  padding:5px 12px;
  border:1px solid var(--border);
  border-radius:4px;
  transition:all .2s;
  white-space:nowrap;
}
.nav-home:hover{border-color:var(--gold);color:var(--gold);}
.nav-home svg{flex-shrink:0;}
.nav-title{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.15em;color:var(--text-muted);}
.nav-tags{display:flex;gap:8px;}
.tag{
  font-family:'JetBrains Mono',monospace;font-size:10px;
  padding:3px 10px;border:1px solid var(--border);
  color:var(--text-dim);letter-spacing:.1em;
}
  
</style>
</head>
<body>

<nav>
  <div class="nav-left">
    <a href="https://nohdaeyoung.github.io/documents/" class="nav-home">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
